#
# Environment
#

# Ensure path arrays do not contain duplicates
typeset -gU cdpath fpath mailpath path

path=(
  $HOME/.local/share/mise/shims(N)
  $HOME/.local/bin(N)
  $HOME/{,s}bin(N)
  /opt/{homebrew,local}/{,s}bin(N)
  /usr/local/{,s}bin(N)
  $path
)

if [[ -z "$LANG" ]]; then
  export LANG='en_US.UTF-8'
fi

if [[ -z "$PAGER" ]]; then
  export PAGER='less'
fi

if [[ -z "$LESS" ]]; then
  export LESS='-g -i -M -R -S -w -X -z-4'
fi

[[ -f "$HOME/.cargo/env" ]] && source "$HOME/.cargo/env"

# required for 256 color tmux terminal
export TERMINFO_DIRS="$HOME/.local/share/terminfo/"

# add the 1Password SSH agent
if [[ "$OSTYPE" == "darwin"* ]]; then
  export SSH_AUTH_SOCK=~/Library/Group\ Containers/2BUA8C4S2C.com.1password/t/agent.sock
fi

#
# Zsh options
#

# history
HISTFILE="${HOME}/.zsh_history"
HISTSIZE=10000
SAVEHIST=10000
setopt EXTENDED_HISTORY SHARE_HISTORY HIST_EXPIRE_DUPS_FIRST
setopt HIST_IGNORE_DUPS HIST_IGNORE_SPACE HIST_SAVE_NO_DUPS HIST_VERIFY

# directory
setopt AUTO_CD AUTO_PUSHD PUSHD_IGNORE_DUPS PUSHD_SILENT EXTENDED_GLOB

# general
setopt INTERACTIVE_COMMENTS NO_BEEP

# emacs key bindings
bindkey -e

# word movement (option+arrow in terminals that send escape sequences)
bindkey '\e[1;3D' backward-word
bindkey '\e[1;3C' forward-word

#
# Plugins (antidote)
#
# We use a static bundle (~/.zsh_plugins.zsh) instead of `antidote load`
# to avoid ~20ms of overhead on every shell. The bundle is a plain list
# of fpath+= and source commands generated from ~/.zsh_plugins.txt.
#
# The bundle auto-rebuilds when the plugin list is newer. You can also
# rebuild manually with `make antidote` or `make update`.
#

if [[ "$OSTYPE" == "darwin"* ]]; then
  FPATH="/opt/homebrew/share/zsh/site-functions:${FPATH}"
  antidote_cache="$HOME/Library/Caches/antidote"
else
  antidote_cache="${XDG_CACHE_HOME:-$HOME/.cache}/antidote"
fi

zsh_plugins_txt="${ZDOTDIR:-${HOME}}/.zsh_plugins.txt"
zsh_plugins_zsh="${ZDOTDIR:-${HOME}}/.zsh_plugins.zsh"
if [[ ! -e "$zsh_plugins_zsh" || "$zsh_plugins_txt" -nt "$zsh_plugins_zsh" ]]; then
  source "${HOME}/.antidote/antidote.zsh"
  antidote bundle < "$zsh_plugins_txt" > "$zsh_plugins_zsh"
fi

# compinit must run BEFORE the plugin bundle is sourced: fzf-tab needs to
# wrap the completion widget, and autosuggestions/syntax-highlighting need
# to wrap zle widgets that compinit registers. But compinit needs the
# zsh-completions fpath entry that the bundle would normally provide, so
# we add it explicitly here first.
fpath=("$antidote_cache/https-COLON--SLASH--SLASH-github.com-SLASH-zsh-users-SLASH-zsh-completions/src" $fpath)
autoload -Uz compinit && compinit -C
autoload -U +X bashcompinit && bashcompinit
zstyle ':completion:*:descriptions' format '[%d]'

source "$zsh_plugins_zsh"
unset zsh_plugins_txt zsh_plugins_zsh antidote_cache

# bind up/down to history-substring-search (from antidote plugin)
bindkey '^[[A' history-substring-search-up
bindkey '^[[B' history-substring-search-down

#
# Prompt
#

eval "$(starship init zsh)"

# Terminal title: directory + running command
set_terminal_title_preexec() { print -Pn "\e]0;%~ · ${1}\a" }
preexec_functions+=(set_terminal_title_preexec)

#
# Tools
#

# editor
if command -v nvim >/dev/null; then
  alias vim=nvim
  EDITOR=nvim
  VISUAL=nvim
else
  EDITOR=vim
  VISUAL=vim
fi

# use bat for cat and man pages if available
if command -v bat >/dev/null; then
  alias cat=bat
  export MANPAGER="sh -c 'col -bx | bat -l man -p --theme=zenburn'"
fi

# use duf instead of df
if command -v duf >/dev/null; then
  alias df='duf'
fi

# use eza instead of ls if available
if command -v eza >/dev/null; then
  alias ls='eza'
  # only add --git if successful
  if $(eza --git) &>/dev/null; then
    alias ls='eza --git'
  fi
fi
alias ll='ls -l'
alias la='ls -la'

# configure fzf for fuzzy-finding (zenburn palette)
export FZF_DEFAULT_OPTS="
  --color=bg+:#4F4F4F,bg:#3F3F3F,fg:#DCDCCC,fg+:#DCDCCC
  --color=hl:#F0DFAF,hl+:#F0DFAF,info:#7F9F7F,marker:#CC9393
  --color=prompt:#8CD0D3,spinner:#DC8CC3,pointer:#CC9393,header:#8CD0D3
  --color=gutter:#3F3F3F,border:#5F5F5F"
[ -f ~/.fzf.zsh ] && source ~/.fzf.zsh

# use htop instead of top
if command -v htop >/dev/null; then
  alias top=htop
fi

# mise: shims dir is on PATH (see top of file), no activate hook needed

# configure zoxide
command -v zoxide >/dev/null && eval "$(zoxide init zsh)"

#
# Aliases
#

# config file edits
ce() {
  vim ~/.config/$1
}
# rebuild zsh completion cache (run after installing new CLI tools)
zsh-rebuild() { rm -f ~/.zcompdump && exec zsh }

alias se='vim ~/.ssh/config'
alias te='vim ~/.tmux.conf.local'
alias ve='vim ~/.vim/vimrc'
alias ze='vim ~/.zshrc'

# git
alias ga='git add'
alias gap='git add -p'
alias gb='git branch'
alias gba='git branch -a'
alias gc='git commit'
alias gcm='git commit -m'
alias gco='git checkout'
alias gcob='git checkout -b'
alias gd='git diff'
alias gdc='git diff --cached'
alias gf='git fetch'
alias gfo='git fetch origin'
alias gl='git log'
alias glp='git log -p'
alias gp='git push'
alias gpf='git push -f'
alias gpu='git push -u'
alias gr='git rebase'
alias grc='git rebase --continue'
alias gri='git rebase -i'
alias grim='git rebase -i origin/main'
alias gro='git fetch origin && git rebase origin'
alias grom='git fetch origin && git rebase origin/main'
alias grm='git rm'
alias gs='git status'

# jq
alias jqf='jq -r | fzf --tac'
alias jql='jq -C | bat'
alias jqr='jqfzf'

# lazygit
alias gg='lazygit'

# kiro
alias k='kiro-cli'
alias kr='kiro-cli chat --resume-picker'

#
# Functions
#
# zip and encrypt a directory
zipenc() {
  [ -n "$1" ] || return 1
  zip --encrypt --junk-paths --exclude \*.DS_Store -r "$(basename $1)" $1
}

# jump to a git worktree
gw() {
  local dir
  dir=$(git worktree list | awk '{print $1}' | fzf) && cd "$dir"
}

# virtualenv helpers
lsenv() {
  ls -a | grep -E "\.\w+env$" --color=never
}

srcenv() {
  source ${1:-.venv}/bin/activate
}

mkenv() {
  local venv="${1:-.venv}"
  python3 -m venv $venv && srcenv $venv
}

rmenv() {
  rm -rf "${1:-.venv}"
}

pypi() {
  open https://www.pypi.org/project/$1
}

# macOS VPN utilities
if [[ "$OSTYPE" == "darwin"* ]]; then
  vpnls() {
    scutil --nc list
  }

  vpnst() {
    scutil --nc status $*
  }

  vpnon() {
    networksetup -connectpppoeservice $*
  }

  vpnoff() {
    networksetup -disconnectpppoeservice $*
  }
fi

claude-rc() {
  # if name not provided, use name of parent dir
  local name="${1:-${PWD##*/}}"

  caffeinate -dis &
  local caf_pid=$!

  cleanup() {
    kill $caf_pid 2>/dev/null
    trap - EXIT INT TERM HUP
  }

  trap cleanup EXIT INT TERM HUP

  claude remote-control --name "$name"
  local rc=$?

  cleanup
  return $rc
}
