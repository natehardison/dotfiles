[user]
    name = Nate Hardison
    email = natehardison@gmail.com

[core]
    editor = vim
    pager = delta 2>/dev/null || less

[interactive]
    diffFilter = delta --color-only --features=interactive 2>/dev/null || cat

[delta]
    features = decorations
    navigate = true
    side-by-side = true
    syntax-theme = zenburn

[delta "interactive"]
    keep-plus-minus-markers = false

[delta "decorations"]
    commit-decoration-style = blue ol
    commit-style = raw
    file-style = omit
    hunk-header-decoration-style = blue box
    hunk-header-file-style = red
    hunk-header-line-number-style = "#067a00"
    hunk-header-style = file line-number syntax

[merge]
    conflictstyle = diff3
    tool = vimdiff

[diff]
    colorMoved = default
    tool = vimdiff

[init]
    defaultBranch = main

[push]
    default = current

[pull]
    rebase = true

[alias]
    dc = diff --cached
    ds = diff --stat
    st = status
    hist = log --pretty=format:\"%h %ad | %s%d [%an]\" --graph --date=short
    wip = commit -a -m"WIP"
    sw = switch
    dag = log --graph --format='format:%C(yellow)%h%C(reset) %C(blue)%an <%ae>%C(reset) %C(magenta)%cr%C(reset)%C(auto)%d%C(reset)%n%s' --date-order
    main = switch main

[pager]
    color = true

[color]
    branch = auto
    diff = auto
    interactive = auto
    status = auto
    ui = auto

[github]
    user = natehardison

[sendemail]
    smtpserver = smtp.gmail.com
    smtpuser = $GMAIL_USER
    smtppass = $GMAIL_PASSWORD
    smtpencryption = tls
    smtpserverport = 587
    chainreplyto = false

# https://michaelheap.com/git-ignore-rev/
[blame]
    # Mark any lines that have had a commit skipped using --ignore-rev with a `?`
    markIgnoredLines = true
    # Mark any lines that were added in a skipped commit and can not be attributed with a `*`
    markUnblamableLines = true

[includeIf "gitdir:eero-inc/"]
    path = ~/.config/git/config.d/eero

[includeIf "gitdir:amazon/"]
    path = ~/.config/git/config.d/amazon

# don't set tracking branch to main on "git checkout -b <new branch>"
[branch]
    autoSetupMerge = false

[filter "lfs"]
    smudge = git-lfs smudge -- %f
    process = git-lfs filter-process
    required = true
    clean = git-lfs clean -- %f
